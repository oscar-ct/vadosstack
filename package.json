{
  "name": "vadosstack",
  "version": "2.2.0",
  "private": true,
  "engines": {
    "node": ">=20.17"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "prisma generate",
    "build": "next build --webpack",
    "start": "next start",
    "pretypecheck": "prisma generate",
    "typecheck": "next typegen && tsc --noEmit",
    "lint": "biome lint",
    "format": "biome format --write",
    "check": "biome check",
    "check:fix": "biome check --write",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "prepare": "husky",
    "generate:presets": "ts-node -P tsconfig.scripts.json src/scripts/generate-theme-presets.ts",
    "seed:customers": "ts-node -P tsconfig.scripts.json src/scripts/seed-customers.ts",
    "seed:jobs": "ts-node -P tsconfig.scripts.json src/scripts/seed-jobs.ts",
    "seed:auth-user": "ts-node -P tsconfig.scripts.json src/scripts/seed-auth-user.ts",
    "setup:auth": "ts-node -P tsconfig.scripts.json src/scripts/setup-auth.ts",
    "setup:job-pricing": "ts-node -P tsconfig.scripts.json src/scripts/setup-job-pricing.ts",
    "setup:invoices": "ts-node -P tsconfig.scripts.json src/scripts/setup-invoices.ts",
    "setup:estimates": "ts-node -P tsconfig.scripts.json src/scripts/setup-estimates.ts",
    "setup:time-tracking": "ts-node -P tsconfig.scripts.json src/scripts/setup-time-tracking.ts",
    "setup:estimate-records": "ts-node -P tsconfig.scripts.json src/scripts/setup-estimate-records.ts",
    "setup:services": "ts-node -P tsconfig.scripts.json src/scripts/setup-services.ts"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.19.3",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "geist": "^1.7.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.12.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.74.0",
    "react-resizable-panels": "^4.10.0",
    "recharts": "^3.8.0",
    "shadcn": "^4.6.0",
    "simple-icons": "^16.18.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.12",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.1.5",
    "ts-node": "^10.9.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
