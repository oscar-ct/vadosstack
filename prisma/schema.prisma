generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id              String                @id @default(cuid())
  ownerId         String
  name            String
  email           String?
  billingStatus   String                @default("Pending")
  notes           String?
  joinedAt        DateTime              @default(now())
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  owner           User                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  addresses       CustomerAddress[]
  phoneNumbers    CustomerPhoneNumber[]
  jobs            Job[]
  estimateRecords EstimateRecord[]
  leads           Lead[]
  tasks           Task[]

  @@unique([id, ownerId])
  @@unique([ownerId, email])
  @@index([ownerId])
  @@map("customers")
}

model Job {
  id                String             @id @default(cuid())
  ownerId           String
  customerId        String?
  description       String
  serviceLocation   String?
  dateBegin         DateTime?
  dateEnd           DateTime?
  estimatedCost     Decimal?
  laborCost         Decimal?           @default(0)
  laborItems        String             @default("[]")
  jobType           String             @default("Residential")
  measurementRooms  String             @default("[]")
  materialTaxRate   Decimal?           @default(0)
  materials         String             @default("[]")
  paymentStatus     String             @default("Pending Payment")
  depositPaid       Decimal?           @default(0)
  amountPaid        Decimal?           @default(0)
  finalCost         Decimal?
  scope             String?
  category          String
  status            String             @default("Scheduled")
  pictures          String[]           @default([])
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  owner             User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  customer          Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  invoice           Invoice?
  estimate          Estimate?
  payments          JobPayment[]
  timeEntries       TimeEntry[]
  timeEntryRequests TimeEntryRequest[]
  tasks             Task[]

  @@unique([id, ownerId])
  @@index([ownerId])
  @@index([customerId])
  @@index([status])
  @@index([dateBegin])
  @@index([category])
  @@map("jobs")
}

model JobPayment {
  id              String   @id @default(cuid())
  ownerId         String
  jobId           String
  paidOn          DateTime @default(now())
  amount          Decimal
  paymentType     String   @default("deposit")
  method          String
  referenceNumber String?
  description     String
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  owner           User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  job             Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([id, ownerId])
  @@index([ownerId])
  @@index([jobId])
  @@index([paidOn])
  @@map("job_payments")
}

model User {
  id                  String               @id @default(cuid())
  name                String?
  companyName         String
  companyEmail        String?
  companyPhone        String?
  companyLogoDataUrl  String?
  companyLogoKey      String?
  companyLogoType     String?
  estimateValidDays   Int                  @default(15)
  invoiceDueDays      Int                  @default(15)
  authProviders       String[]             @default(["email"])
  email               String               @unique
  passwordHash        String
  admin               Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  customers           Customer[]
  leads               Lead[]
  jobs                Job[]
  jobPayments         JobPayment[]
  invoices            Invoice[]
  estimates           Estimate[]
  estimateRecords     EstimateRecord[]
  emailRecords        EmailRecord[]
  emailTemplates      EmailTemplate[]
  serviceTemplates    ServiceTemplate[]
  employees           Employee[]
  timeEntries         TimeEntry[]
  timeEntryRequests   TimeEntryRequest[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  googleMailAccount   GoogleMailAccount?
  tasks               Task[]

  @@map("users")
}

model EstimateRecord {
  id                String    @id @default(cuid())
  ownerId           String
  customerId        String?
  description       String
  serviceLocation   String?
  dateBegin         DateTime?
  dateEnd           DateTime?
  laborCost         Decimal?  @default(0)
  laborItems        String    @default("[]")
  jobType           String    @default("Residential")
  measurementRooms  String    @default("[]")
  materialTaxRate   Decimal?  @default(0)
  materials         String    @default("[]")
  estimatedTotal    Decimal?  @default(0)
  scope             String?
  category          String
  status            String    @default("Draft")
  notes             String?
  convertedJobId    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  owner             User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  customer          Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  printableEstimate Estimate?
  lead              Lead?
  tasks             Task[]

  @@unique([id, ownerId])
  @@index([ownerId])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@map("estimate_records")
}

model Lead {
  id               String          @id @default(cuid())
  ownerId          String
  customerId       String?
  estimateRecordId String?         @unique
  name             String
  email            String?
  phone            String?
  source           String?
  serviceType      String?
  serviceLocation  String?
  estimatedValue   Decimal?
  status           String          @default("New")
  priority         String          @default("Normal")
  notes            String?
  followUpAt       DateTime?
  lostReason       String?
  convertedAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  owner            User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  customer         Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  estimateRecord   EstimateRecord? @relation(fields: [estimateRecordId], references: [id], onDelete: SetNull)

  @@unique([id, ownerId])
  @@index([ownerId])
  @@index([customerId])
  @@index([estimateRecordId])
  @@index([status])
  @@index([followUpAt])
  @@index([source])
  @@map("leads")
}

model Task {
  id               String          @id @default(cuid())
  ownerId          String
  customerId       String?
  jobId            String?
  estimateRecordId String?
  title            String
  notes            String?
  location         String?
  scheduledFor     DateTime
  status           String          @default("Open")
  priority         String          @default("Normal")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  owner            User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  customer         Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  job              Job?            @relation(fields: [jobId], references: [id], onDelete: SetNull)
  estimateRecord   EstimateRecord? @relation(fields: [estimateRecordId], references: [id], onDelete: SetNull)

  @@unique([id, ownerId])
  @@index([ownerId])
  @@index([customerId])
  @@index([jobId])
  @@index([estimateRecordId])
  @@index([scheduledFor])
  @@index([status])
  @@map("tasks")
}

model Invoice {
  id                String    @id @default(cuid())
  ownerId           String
  jobId             String    @unique
  customerId        String?
  customerName      String?
  customerEmail     String?
  customerPhone     String?
  jobTitle          String
  jobDescription    String?
  serviceLocation   String?
  dateBegin         DateTime?
  dateEnd           DateTime?
  laborCost         Decimal   @default(0)
  materialTaxRate   Decimal   @default(0)
  materials         String    @default("[]")
  materialsSubtotal Decimal   @default(0)
  materialTaxAmount Decimal   @default(0)
  finalCost         Decimal   @default(0)
  depositPaid       Decimal   @default(0)
  amountPaid        Decimal   @default(0)
  balanceDue        Decimal   @default(0)
  paymentStatus     String
  jobStatus         String
  issuedAt          DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  owner             User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  job               Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([id, ownerId])
  @@index([ownerId])
  @@index([jobId])
  @@index([customerId])
  @@index([issuedAt])
  @@map("invoices")
}

model Estimate {
  id                String          @id @default(cuid())
  ownerId           String
  jobId             String?         @unique
  estimateRecordId  String?         @unique
  customerId        String?
  customerName      String?
  customerEmail     String?
  customerPhone     String?
  jobTitle          String
  jobDescription    String?
  serviceLocation   String?
  dateBegin         DateTime?
  dateEnd           DateTime?
  laborCost         Decimal         @default(0)
  materialTaxRate   Decimal         @default(0)
  materials         String          @default("[]")
  materialsSubtotal Decimal         @default(0)
  materialTaxAmount Decimal         @default(0)
  estimatedTotal    Decimal         @default(0)
  jobStatus         String
  issuedAt          DateTime        @default(now())
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  owner             User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  job               Job?            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  estimateRecord    EstimateRecord? @relation(fields: [estimateRecordId], references: [id], onDelete: Cascade)

  @@unique([id, ownerId])
  @@index([ownerId])
  @@index([jobId])
  @@index([estimateRecordId])
  @@index([customerId])
  @@index([issuedAt])
  @@map("estimates")
}

model ServiceTemplate {
  id              String   @id @default(cuid())
  ownerId         String
  title           String
  description     String?
  category        String   @default("Other")
  notes           String?
  laborItems      String   @default("[]")
  materialTaxRate Decimal  @default(8.25)
  materials       String   @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  owner           User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([id, ownerId])
  @@index([ownerId])
  @@index([category])
  @@map("service_templates")
}

model EmailTemplate {
  id        String   @id @default(cuid())
  ownerId   String
  title     String
  scope     String
  subject   String
  bodyText  String
  bodyHtml  String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([id, ownerId])
  @@unique([ownerId, scope, title])
  @@index([ownerId])
  @@index([scope])
  @@map("email_templates")
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model PendingAccountConfirmation {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  companyName  String
  passwordHash String
  tokenHash    String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([expiresAt])
  @@map("pending_account_confirmations")
}

model RateLimitAttempt {
  id        String   @id @default(cuid())
  action    String
  keyHash   String
  createdAt DateTime @default(now())

  @@index([action, keyHash, createdAt])
  @@index([createdAt])
  @@map("rate_limit_attempts")
}

model GoogleMailAccount {
  id                 String   @id @default(cuid())
  userId             String   @unique
  googleSubject      String
  email              String
  refreshTokenCipher String
  scopes             String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([googleSubject])
  @@map("google_mail_accounts")
}

model EmailRecord {
  id             String   @id @default(cuid())
  ownerId        String
  documentType   String
  documentId     String?
  documentNumber String?
  recipientName  String?
  recipientEmail String?
  senderEmail    String?
  subject        String?
  documentTotal  Decimal?
  status         String
  errorMessage   String?
  sentAt         DateTime @default(now())
  createdAt      DateTime @default(now())
  owner          User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([id, ownerId])
  @@index([ownerId])
  @@index([documentType])
  @@index([documentId])
  @@index([status])
  @@index([sentAt])
  @@map("email_records")
}

model Employee {
  id                String             @id @default(cuid())
  ownerId           String
  employeeNumber    String
  name              String
  email             String?
  phone             String?
  jobTitle          String?
  department        String?
  employmentType    String            @default("Employee")
  payType           String            @default("Hourly")
  payRate           Decimal?
  startDate         DateTime?
  endDate           DateTime?
  address           String?
  emergencyName     String?
  emergencyPhone    String?
  emergencyRelation String?
  notes             String?
  active            Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  owner             User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  timeEntries       TimeEntry[]
  timeEntryRequests TimeEntryRequest[]

  @@unique([id, ownerId])
  @@unique([ownerId, employeeNumber])
  @@index([ownerId])
  @@index([active])
  @@index([department])
  @@index([employmentType])
  @@map("employees")
}

model TimeEntry {
  id           String   @id @default(cuid())
  ownerId      String
  employeeId   String
  jobId        String?
  workedOn     DateTime
  startTime    String?
  endTime      String?
  hours        Decimal
  deductLunch  Boolean  @default(true)
  lunchMinutes Int      @default(60)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  owner        User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  job          Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@unique([id, ownerId])
  @@index([ownerId])
  @@index([employeeId])
  @@index([jobId])
  @@index([workedOn])
  @@map("time_entries")
}

model TimeEntryRequest {
  id           String    @id @default(cuid())
  ownerId      String
  employeeId   String
  timeEntryId  String?
  jobId        String?
  action       String
  status       String    @default("Pending")
  workedOn     DateTime?
  startTime    String?
  endTime      String?
  hours        Decimal?
  deductLunch  Boolean   @default(true)
  lunchMinutes Int       @default(60)
  notes        String?
  requestedAt  DateTime  @default(now())
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  owner    User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  job      Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([employeeId])
  @@index([jobId])
  @@index([status])
  @@index([requestedAt])
  @@map("time_entry_requests")
}

model CustomerAddress {
  id         String   @id @default(cuid())
  customerId String
  label      String?
  line1      String
  line2      String?
  city       String?
  state      String?
  postalCode String?
  country    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_addresses")
}

model CustomerPhoneNumber {
  id         String   @id @default(cuid())
  customerId String
  label      String?
  value      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_phone_numbers")
}
